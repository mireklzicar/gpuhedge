[5.1452, "o", "\u001b[1mGPUHedge demo\u001b[0m \u2014 simulated providers, real policy engines \u001b[1m(\u001b[0m2\u001b[1;36m0x\u001b[0m compressed time\u001b[1m)\u001b[0m. Traces: \r\n\u001b[35m/tmp/\u001b[0m\u001b[95mgpuhedge-demo-etp5ra3b\u001b[0m\r\n  \u001b[36mflashy\u001b[0m: usually ~\u001b[1;36m6\u001b[0m s, sometimes ~\u001b[1;36m90\u001b[0m-\u001b[1;36m120\u001b[0m s behind a long queue delay\r\n  \u001b[35msteady\u001b[0m: steady ~\u001b[1;36m16\u001b[0m-\u001b[1;36m20\u001b[0m s, rare ~\u001b[1;36m85\u001b[0m-\u001b[1;36m105\u001b[0m s tail\r\n  \u001b[32mreserve\u001b[0m: predictable ~\u001b[1;36m26\u001b[0m-\u001b[1;36m32\u001b[0m s escalation target\r\n\r\n\u001b[1;4msingle\u001b[0m \u2014 singl\u001b[1;92me:f\u001b[0mlashy\r\n"]
